{
  "name": "score",
  "version": "0.1.0",
  "description": "Deterministic leitmotif and ambience generator for games, interactive media, and any project needing looping music from a shared theme",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "params": "tsx src/cli/main.ts params",
    "compose": "tsx src/cli/main.ts compose",
    "ambience": "tsx src/cli/main.ts ambience",
    "batch": "tsx src/cli/main.ts batch",
    "preview": "tsx src/cli/main.ts preview",
    "serve": "tsx src/cli/main.ts serve",
    "analyze": "tsx src/cli/main.ts analyze",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "verify": "tsx scripts/verify.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "openai": "^6.42.0",
    "zod": "^3.24.0",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
